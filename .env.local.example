# Turso (hosted SQLite) — required for Vercel deployment
# Get these from: turso db show <db-name> --url / turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# For local development, leave these commented out.
# The app defaults to file:expenses.db (local SQLite file).

# Node environment (development, production, test)
NODE_ENV=development
